{
  "name": "mobilcharge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "TURBO_CACHE_DIR=.turbo/cache turbo dev",
    "build": "TURBO_CACHE_DIR=.turbo/cache turbo build",
    "lint": "TURBO_CACHE_DIR=.turbo/cache turbo lint",
    "test": "TURBO_CACHE_DIR=.turbo/cache turbo test",
    "db:generate": "npm --workspace @mobilcharge/api run db:generate",
    "db:migrate": "npm --workspace @mobilcharge/api run db:migrate",
    "db:seed": "npm --workspace @mobilcharge/api run db:seed",
    "dev:web": "npm --workspace @mobilcharge/web run dev",
    "dev:api": "npm --workspace @mobilcharge/api run dev",
    "dev:mobile": "npm --workspace @mobilcharge/mobile run dev"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.4.5",
    "prettier": "^3.3.3"
  }
}
