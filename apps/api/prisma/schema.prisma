generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  DRIVER
}

enum BookingStatus {
  PENDING
  ACCEPTED
  EN_ROUTE
  CHARGING
  COMPLETED
  CANCELLED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String
  phoneNumber   String?
  role          UserRole       @default(USER)
  profileImage  String?
  bookings      Booking[]      @relation("CustomerBookings")
  driverJobs    Booking[]      @relation("DriverBookings")
  driverProfile DriverProfile?
  vehicles      Vehicle[]
  otps          Otp[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DriverProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  truckName           String?
  plateNumber         String?
  isAvailable         Boolean  @default(true)
  latitude            Float?
  longitude           Float?
  lastLocationUpdate  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Vehicle {
  id              String   @id @default(cuid())
  brand           String
  model           String
  year            Int
  batteryCapacity Float
  portType        String
  plateNumber     String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Booking {
  id                   String        @id @default(cuid())
  invoiceId            String        @unique
  customerId           String
  customer             User          @relation("CustomerBookings", fields: [customerId], references: [id])
  driverId             String?
  driver               User?         @relation("DriverBookings", fields: [driverId], references: [id])
  status               BookingStatus @default(PENDING)
  isEmergency          Boolean       @default(false)
  rechargeAddress      String
  originLat            Float?
  originLng            Float?
  destLat              Float?
  destLng              Float?
  reservationAt        DateTime
  carModel             String
  vehicleId            String?
  vehicle              Vehicle?      @relation(fields: [vehicleId], references: [id])
  batteryLevel         Int?
  batteryTarget        Int?
  kilometresLeft       Int?
  chargingTimeEstimate String?
  estimatedPrice       Float?
  actualPrice          Float?
  distance             Float?
  duration             Float?
  comments             String?
  vehicleImageUrl      String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model PricingPlan {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  priceLabel  String
  features    String[]
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  user      User?    @relation(fields: [email], references: [email], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}
